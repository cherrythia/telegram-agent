# --- Required everywhere ---
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_WEBHOOK_SECRET=your-random-secret-here
ALLOWED_CHAT_IDS=your-telegram-chat-id

# --- LLM provider ---
# anthropic (default) | openai | openrouter | gemini
LLM_PROVIDER=anthropic
# Optional model override (defaults: claude-sonnet-4-6 / gpt-4o-mini /
# openai/gpt-4o-mini / gemini-2.0-flash)
# LLM_MODEL=
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=

# --- Storage: local (dev) or github (Cloud Run) ---
STORE=local
# local mode: absolute paths to your context repo checkout and skills dirs
AIOS_ROOT=/absolute/path/to/your/context-repo
SKILLS_DIR_GLOBAL=/absolute/path/to/.claude/skills
SKILLS_DIR_PROJECT=/absolute/path/to/your/context-repo/.claude/skills
# github mode (STORE=github):
# GITHUB_TOKEN=fine-grained PAT with Contents read/write on the repo below
# GITHUB_REPO=your-github-user/your-private-context-repo
# GITHUB_BRANCH=main

PORT=3000
